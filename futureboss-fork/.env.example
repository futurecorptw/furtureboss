# Required
ANTHROPIC_API_KEY=sk-ant-...

# Channels (fill in as needed)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Multi-runtime (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# WhatsApp (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Feishu (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Google Workspace OAuth (optional — Gmail / Drive / Docs / Sheets / Forms / Calendar / Apps Script)
# 預先填入後，Dashboard 的「Google」連接會直接顯示為已設定，使用者只要點「Authenticate」
# → Google 同意畫面 → 完成授權，完全不必自己去 Google Cloud Console 建專案。
# 取得方式：在 Google Cloud Console 建一個 OAuth 2.0「電腦/Desktop」用戶端，
# 或向本專案維運者索取共用的 client_id / secret。
# 注意：這是「OAuth 用戶端」憑證（讓使用者各自授權自己的帳號），
# 不是任何人的 refresh token / access token —— 後者屬個人機密，切勿放進此檔或 repo。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
